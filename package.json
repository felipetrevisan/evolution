{
  "name": "evolution",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "db:migrate": "turbo run db:migrate --filter=@evolution/api",
    "db:seed-config": "turbo run db:seed-config --filter=@evolution/api",
    "test": "turbo run test --filter=@evolution/domain --filter=@evolution/api",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "dev:web": "turbo run dev --filter=@evolution/web",
    "dev:api": "turbo run dev --filter=@evolution/api",
    "dev": "turbo run dev --filter=./apps/*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  }
}
